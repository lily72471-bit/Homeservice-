@page "/supplier"
@inject AppStateService AppState
@inject AdminApiService AdminApi
@inject NavigationManager Nav
<div class="dashboard-container">
    <div class="welcome-card">
        <div class="welcome-content">
            <h2>Welcome, @AppState.CurrentAppUser?.FullName!</h2>
            <p>Manage your assigned orders and update their status</p>
        </div>
    </div>
    <div class="stats-grid">
        <div class="stat-card stat-primary">            <div class="stat-icon"><i class="bi bi-clipboard-check"></i></div>
            <div class="stat-content">
                <div class="stat-value">@assignedOrders.Count</div>
                <div class="stat-label">Assigned Orders</div>
            </div>
        </div>
        <div class="stat-card stat-warning">
            <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
            <div class="stat-content">
                <div class="stat-value">@pendingOrders</div>
                <div class="stat-label">Pending</div>
            </div>
        </div>
        <div class="stat-card stat-info">
            <div class="stat-icon"><i class="bi bi-arrow-repeat"></i></div>
            <div class="stat-content">
                <div class="stat-value">@inProgressOrders</div>
                <div class="stat-label">In Progress</div>
            </div>
        </div>
        <div class="stat-card stat-success">
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
            <div class="stat-content">
                <div class="stat-value">@completedOrders</div>
                <div class="stat-label">Completed</div>
            </div>
        </div>
    </div>

    <div class="section-header">
        <h3>Recent Assigned Orders</h3>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/supplier/orders")'>
            View All Orders
        </button>
    </div>

    @if (loading)
    {
        <div class="loading-spinner"><i class="bi bi-arrow-repeat spin"></i> Loading orders...</div>
    }
    else if (!assignedOrders.Any())
    {
        <div class="empty-state">
            <i class="bi bi-clipboard-check"></i>
            <h3>No Orders Yet</h3>
            <p>You don't have any assigned orders at the moment.</p>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in assignedOrders.Take(5))
            {
                <div class="order-card" @onclick='() => Nav.NavigateTo("/supplier/orders")'>
                    <div class="order-icon"><i class="bi bi-receipt"></i></div>
                    <div class="order-info">
                        <h4>@order.ServiceName</h4>
                        <p>@order.CategoryName &middot; @order.ScheduledDate.ToString("MMM dd, yyyy") @order.ScheduledTime</p>
                    </div>
                    <div class="order-right">
                        <div class="order-price">@order.TotalPrice.ToString("N0") IQD</div>
                        <span class="status-badge @GetStatusClass(order.Status)">@order.Status</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool loading = true;
    private List<ServiceOrder> assignedOrders = new();
    private int pendingOrders => assignedOrders.Count(o => o.Status == OrderStatus.Confirmed);
    private int inProgressOrders => assignedOrders.Count(o => o.Status == OrderStatus.InProgress);
    private int completedOrders => assignedOrders.Count(o => o.Status == OrderStatus.Completed);

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.IsLoggedIn || AppState.CurrentAppUser?.Role != UserRole.Supplier)
        {
            Nav.NavigateTo("/login", true);
            return;
        }
        await LoadOrders();
        loading = false;
    }

    private async Task LoadOrders()
    {
        // Get orders from API (database)
        var allOrders = await AdminApi.GetOrdersAsync();
        
        // Filter to only orders assigned to this supplier
        var supplierId = AppState.CurrentAppUser?.Id;
        assignedOrders = allOrders
            .Where(o => o.AssignedWorkerId.HasValue && o.AssignedWorkerId == supplierId)
            .OrderByDescending(o => o.CreatedAt)
            .Select(o => new ServiceOrder
            {
                Id = o.Id,
                ServiceId = o.ServiceId,
                ServiceName = o.ServiceName,
                CategoryName = o.CategoryName,
                OrderDate = o.CreatedAt,
                ScheduledDate = o.ScheduledDate,
                ScheduledTime = o.ScheduledTime,
                Address = o.Address,
                Notes = o.Notes,
                TotalPrice = o.TotalPrice,
                Status = Enum.Parse<OrderStatus>(o.Status),
                AssignedWorkerId = o.AssignedWorkerId,
                AssignedWorkerName = o.AssignedWorkerName,
                ContactPhone = o.ContactPhone
            })
            .ToList();
    }
    private string GetStatusClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Pending => "status-pending",
            OrderStatus.Confirmed => "status-confirmed",
            OrderStatus.InProgress => "status-inprogress",
            OrderStatus.Completed => "status-completed",
            OrderStatus.Cancelled => "status-cancelled",
            _ => ""
        };
    }
}
