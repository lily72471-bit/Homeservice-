@inherits LayoutComponentBase
@inject AppStateService AppState
@inject CustomerApiService CustomerApi
@inject NavigationManager Nav
@implements IDisposable
<div class="app-shell">
    <aside class="sidebar @(IsSidebarCollapsed ? "collapsed" : "")">
        <div class="sidebar-header">
            <div class="logo-area">
                <div class="logo-icon">
                    <i class="bi bi-house-gear-fill"></i>
                </div>
                @if (!IsSidebarCollapsed)
                {
                    <div class="logo-text">
                        <span class="app-name">Home Services</span>
                        <span class="app-tagline">Customer Panel</span>
                    </div>
                }
            </div>
            <button class="sidebar-toggle" @onclick="ToggleSidebar" title="@(IsSidebarCollapsed ? "Expand" : "Collapse")">
                <i class="bi @(IsSidebarCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
            </button>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section">
                @if (!IsSidebarCollapsed) { <span class="nav-section-label">Main</span> }
                <NavLink class="nav-item" href="" Match="NavLinkMatch.All" title="Home">
                    <i class="bi bi-house-fill"></i>
                    @if (!IsSidebarCollapsed) { <span>Home</span> }
                </NavLink>
                <NavLink class="nav-item" href="search" title="Search Services">
                    <i class="bi bi-search"></i>
                    @if (!IsSidebarCollapsed) { <span>Search</span> }
                </NavLink>
                <NavLink class="nav-item" href="orders" title="My Orders">
                    <i class="bi bi-receipt-cutoff"></i>
                    @if (!IsSidebarCollapsed) { <span>My Orders</span>
                      
                        @if (pendingCount > 0)
                        {
                            <span class="badge">@pendingCount</span>
                        }
                    }
                </NavLink>
              
                <!-- <NavLink class="nav-item" href="packages" title="Packages">
                    <i class="bi bi-box-seam-fill"></i>
                    @if (!IsSidebarCollapsed) { <span>Packages</span> }
                </NavLink> -->
            </div>
            <div class="nav-section">
                @if (!IsSidebarCollapsed) { <span class="nav-section-label">Services</span> }
                @foreach (var cat in topCategories)
                {
                    <NavLink class="nav-item" href="@($"services/{cat.Id}")" title="@cat.Name">
                        <i class="bi @cat.Icon"></i>
                        @if (!IsSidebarCollapsed) { <span>@cat.Name</span> }
                    </NavLink>
                }
            </div>

            <div class="nav-section">
                @if (!IsSidebarCollapsed) { <span class="nav-section-label">Account</span> }
                <!-- <NavLink class="nav-item" href="worker-registration" title="Become a Pro">
                    <i class="bi bi-person-badge-fill"></i>
                    @if (!IsSidebarCollapsed) { <span>Become a Pro</span> }
                </NavLink> -->
                <NavLink class="nav-item" href="profile" title="My Profile">
                    <i class="bi bi-person-circle"></i>
                    @if (!IsSidebarCollapsed) { <span>My Profile</span> }
                </NavLink>
                <!-- <NavLink class="nav-item" href="settings" title="Settings">
                    <i class="bi bi-gear-fill"></i>
                    @if (!IsSidebarCollapsed) { <span>Settings</span> }
                </NavLink> -->

            </div>
        </nav>
       
 <!-- <div class="wallet-card">
                    <div class="wallet-icon"><i class="bi bi-wallet2"></i></div>
                    <div class="wallet-info">
                        <span class="wallet-label">Wallet</span>
                        <span class="wallet-amount">$@AppState.CurrentUser.WalletBalance.ToString("F2")</span>
                    </div>
                </div> -->

<!-- <div class="wallet-card compact" title="Wallet: $@AppState.CurrentUser.WalletBalance.ToString("F2")">
                    <div class="wallet-icon"><i class="bi bi-wallet2"></i></div>
                </div> -->
        <div class="sidebar-footer">
            @if (!IsSidebarCollapsed)
            {
                <button class="sidebar-logout-btn" @onclick="Logout">
                    <i class="bi bi-box-arrow-left"></i> Logout
                </button>
            }
            else
            {
                <button class="sidebar-logout-btn-compact" @onclick="Logout" title="Logout">
                    <i class="bi bi-box-arrow-left"></i>
                </button>
            }
        </div>
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <div class="top-bar-left">
                <h1 class="page-title">@GetPageTitle()</h1>
            </div>
            <div class="top-bar-right">
                <!-- <button class="top-bar-btn" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notification-dot"></span>
                </button> -->
                <div class="user-avatar" @onclick='() => Nav.NavigateTo("/profile")'>
                    <span>@GetInitials()</span>
                </div>
            </div>
        </header>
        <div class="content-area">
            @Body
        </div>
    </main>
</div>

@code {
    private bool IsSidebarCollapsed = false;
    private int pendingCount;
    private List<CatalogCategory> topCategories = [];

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.IsLoggedIn)
        { Nav.NavigateTo("/login", true); return; }
        AppState.OnStateChanged += HandleStateChanged;
        await LoadDataAsync();
    }
    private async Task LoadDataAsync()
    {
        var userId = AppState.CurrentAppUser?.Id ?? 0;
        if (userId > 0)
        {
            var orders = await CustomerApi.GetMyOrdersAsync(userId);
            pendingCount = orders.Count(o => o.Status is "Pending" or "Confirmed");
        }

        var cats = await CustomerApi.GetCategoriesAsync();
        topCategories = cats.Take(5).ToList();
    }
    private void HandleStateChanged() => InvokeAsync(async () => { await LoadDataAsync(); StateHasChanged(); });

    private void UpdateCounts() { } // kept for compatibility

    private void ToggleSidebar() => IsSidebarCollapsed = !IsSidebarCollapsed;
    private void Logout()
    {
        AppState.Logout();
        Nav.NavigateTo("/login", true);
    }
    private string GetPageTitle()
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        return uri switch
        {
            "" => "Home",
            "search" => "Search Services",
            "orders" => "My Orders",
            "packages" => "Service Packages",
            "profile" => "My Profile",
            "settings" => "Settings",
            "worker-registration" => "Become a Professional",
            _ when uri.StartsWith("services/") => "Services",
            _ when uri.StartsWith("book/") => "Book Service",
            _ => "ServiceHub"
        };
    }
    private string GetInitials()
    {
        var parts = AppState.CurrentUser.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : parts.Length == 1 ? $"{parts[0][0]}" : "U";
    }
    public void Dispose()
    {
        AppState.OnStateChanged -= HandleStateChanged;
    }
}
