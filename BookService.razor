@page "/book/{ServiceId:int}"
@inject AppStateService AppState
@inject CustomerApiService CustomerApi
@inject NavigationManager Nav
<button class="back-btn" @onclick="GoBack">
    <i class="bi bi-arrow-left"></i> Back
</button>
@if (loading)
{
    <div class="loading-spinner"><i class="bi bi-arrow-repeat spin"></i> Loading service...</div>
}
else if (showSuccess)
{
    <div class="alert alert-success" style="margin-top:16px;">
        <i class="bi bi-check-circle-fill"></i>
        Service booked successfully! Your order has been placed.
    </div>
}
else if (service != null)
{
    <div class="detail-page">
        <div class="detail-header">
            <div class="detail-icon">
                <i class="bi @service.Icon"></i>
            </div>
            <div class="detail-info">
                <h2>@service.Name</h2>
                <p>@service.Description</p>
                <div class="service-meta" style="margin-top: 8px;">
                    <span class="rating"><i class="bi bi-star-fill" style="color: #FFC107;"></i> @service.Rating</span>
                    <span>(@service.ReviewCount reviews)</span>
                    <span style="margin-left: 8px;"><i class="bi bi-clock"></i> @service.EstimatedDuration</span>
                </div>
            </div>
        </div>
        <div class="summary-card">
            <div class="summary-row">
                <span class="label">Base Price</span>
                <span class="value">@service.BasePrice.ToString("N0") IQD</span>
            </div>
            <div class="summary-row">
                <span class="label">Category</span>
                <span class="value">@categoryName</span>
            </div>
            <div class="summary-row">
                <span class="label">Estimated Duration</span>
                <span class="value">@service.EstimatedDuration</span>
            </div>
        </div>
        <EditForm Model="order" OnValidSubmit="HandleSubmit">
            <div class="form-section">
                <h3><i class="bi bi-calendar-event"></i> Schedule</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label>Preferred Date <span class="required">*</span></label>
                        <InputDate class="form-control" @bind-Value="order.ScheduledDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label>Preferred Time <span class="required">*</span></label>
                        <select class="form-control" @bind="order.ScheduledTime">
                            <option value="">Select time slot</option>
                            <option value="8:00 AM">8:00 AM</option>
                            <option value="9:00 AM">9:00 AM</option>
                            <option value="10:00 AM">10:00 AM</option>
                            <option value="11:00 AM">11:00 AM</option>
                            <option value="12:00 PM">12:00 PM</option>
                            <option value="1:00 PM">1:00 PM</option>
                            <option value="2:00 PM">2:00 PM</option>
                            <option value="3:00 PM">3:00 PM</option>
                            <option value="4:00 PM">4:00 PM</option>
                            <option value="5:00 PM">5:00 PM</option>
                            <option value="6:00 PM">6:00 PM</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-section">
                <h3><i class="bi bi-geo-alt"></i> Location</h3>
                <div class="form-group">
                    <label>Service Address <span class="required">*</span></label>
                    <InputText class="form-control" @bind-Value="order.Address" placeholder="Enter your full address" />
                </div>
            </div>
            <div class="form-section">
                <h3><i class="bi bi-person"></i> Contact</h3>
                <div class="form-group">
                    <label>Phone Number <span class="required">*</span></label>
                    <InputText class="form-control" @bind-Value="order.ContactPhone" placeholder="Enter your phone number" />
                </div>
            </div>
            <div class="form-section">
                <h3><i class="bi bi-chat-text"></i> Additional Info</h3>
                <div class="form-group">
                    <label>Notes / Special Instructions</label>
                    <InputTextArea class="form-control" @bind-Value="order.Notes" placeholder="Describe any special requirements..." />
                </div>
            </div>
            <div class="summary-card">
                <h3 style="margin-bottom: 16px; font-size: 16px; font-weight: 700;">Order Summary</h3>
                <div class="summary-row">
                    <span class="label">@service.Name</span>
                    <span class="value">@service.BasePrice.ToString("N0") IQD</span>
                </div>
                <div class="summary-row">
                    <span class="label">Service Fee</span>
                    <span class="value">5,000 IQD</span>
                </div>
                <div class="summary-row total">
                    <span class="label">Total</span>
                    <span class="value">@((service.BasePrice + 5000).ToString("N0")) IQD</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="alert" style="background:#FFF3CD;color:#856404;border-radius:8px;padding:12px;margin-bottom:12px;">
                    <i class="bi bi-exclamation-triangle"></i> @errorMsg
                </div>
            }
            <button type="submit" class="btn btn-primary btn-lg btn-block" disabled="@(!IsFormValid() || submitting)">
                @if (submitting) 
                { <i class="bi bi-arrow-repeat spin"></i> } 
                else { <i class="bi bi-check-circle"></i> }
                Confirm Booking
            </button>
        </EditForm>
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-exclamation-triangle"></i>
        <h3>Service not found</h3>
        <p>The requested service doesn't exist.</p>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/")'>Go Home</button>
    </div>
}

@code {
    [Parameter] public int ServiceId { get; set; }
    private CatalogService? service;
    private string categoryName = "General";
    private bool loading = true;
    private bool showSuccess;
    private bool submitting;
    private string errorMsg = string.Empty;
    private BookingForm order = new();
    private class BookingForm
    {
        public DateTime ScheduledDate { get; set; } = DateTime.Today.AddDays(1);
        public string ScheduledTime { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string ContactPhone { get; set; } = string.Empty;
        public string Notes { get; set; } = string.Empty;
    }
    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        service = await CustomerApi.GetServiceAsync(ServiceId);
        if (service != null)
        {
            var cats = await CustomerApi.GetCategoriesAsync();
            categoryName = cats.FirstOrDefault(c => c.Id == service.CategoryId)?.Name ?? "General";
            order = new BookingForm
            {
                Address      = AppState.CurrentUser?.Address ?? string.Empty,
                ContactPhone = AppState.CurrentUser?.Phone ?? string.Empty
            };
        }
        loading = false;
    }
    private bool IsFormValid() =>
        !string.IsNullOrWhiteSpace(order.Address) &&  
        !string.IsNullOrWhiteSpace(order.ScheduledTime) &&  
        !string.IsNullOrWhiteSpace(order.ContactPhone) &&   
        order.ScheduledDate >= DateTime.Today;   
    private async Task HandleSubmit()
    {
        if (!IsFormValid() || service == null || submitting) return;
        var userId = AppState.CurrentAppUser?.Id ?? 0;
        if (userId == 0) { errorMsg = "Please log in before booking."; return; }

        submitting = true;
        errorMsg   = string.Empty;
        var req = new PlaceOrderRequest
        {
            UserId       = userId,
            ServiceId    = service.Id,
            ScheduledDate = order.ScheduledDate,
            ScheduledTime = order.ScheduledTime,
            Address      = order.Address,
            ContactPhone = order.ContactPhone,
            Notes        = order.Notes
        };
        var ok = await CustomerApi.PlaceOrderAsync(req);
        submitting = false;

        if (ok)
        {
            AppState.NotifyStateChanged();
            showSuccess = true;
            await Task.Delay(2000);
            Nav.NavigateTo("/orders");
        }
        else
        {
            errorMsg = "Failed to place order. Please check your connection and try again.";
        }
    }
    private void GoBack()
    {
        if (service != null) Nav.NavigateTo($"/services/{service.CategoryId}");
        else Nav.NavigateTo("/");
    }
}
